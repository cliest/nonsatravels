# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL / Prisma Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nonsatravels

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-key-here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Email Configuration (Resend recommended for better deliverability)
# Using Resend (recommended)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Nonsa Travels <bookings@nonsatravels.com>
REPLY_TO_EMAIL=support@nonsatravels.com

# IMPORTANT: To avoid spam folder issues:
# 1. Use a custom domain email (not @gmail.com or @resend.dev)
# 2. Set up SPF, DKIM, and DMARC records for your domain
# 3. Verify your domain in Resend dashboard
# See: https://resend.com/docs/dashboard/domains/introduction

# Legacy SMTP (use Resend instead)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Skip emails during development
# SKIP_EMAILS=true

# Admin Email for Notifications
ADMIN_EMAIL=admin@nonsatravels.com

# Logo URL for Emails (optional - uses text logo if not set)
# Upload your logo to a service like imgur.com or imgbb.com and paste URL here
# LOGO_URL=https://i.imgur.com/your-logo.png

# Flutterwave Payment (Disabled - Enable when ready)
# FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
# FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key

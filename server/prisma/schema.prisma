generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum BookingStatus {
  pending_payment
  payment_confirmed
  confirmed
  completed
  cancelled
  rejected
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
  no_refund
  cancelled
}

enum PaymentMethod {
  card
  cash
  mobile_money
  paypal
  flutterwave
}

enum ChatStatus {
  active
  closed
  pending
}

enum MessageSender {
  user
  admin
}

enum TripStatus {
  planning
  confirmed
  completed
  cancelled
}

enum ActivityCategory {
  sightseeing
  adventure
  dining
  shopping
  culture
  entertainment
  other
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum PointsType {
  earned
  redeemed
  expired
  bonus
}

enum DiscountType {
  percentage
  fixed
}

enum BlogStatus {
  draft
  published
  archived
}

enum CannedCategory {
  greeting
  faq
  booking
  payment
  policy
  closing
  other
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  password                 String?
  firstName                String
  lastName                 String
  phone                    String?
  avatar                   String?
  googleId                 String?   @unique
  facebookId               String?   @unique
  appleId                  String?   @unique
  role                     Role      @default(user)
  isVerified               Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  magicLinkToken           String?
  magicLinkExpires         DateTime?
  preferences              Json      @default("{\"emailNotifications\":true,\"smsNotifications\":false,\"promotionalEmails\":true,\"currency\":\"USD\",\"language\":\"en\"}")
  loyaltyPoints            Int       @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  blogPosts BlogPost[]
}

model Hotel {
  id                String   @id @default(cuid())
  name              String
  address           String
  city              String
  contact           String?
  roomType          String
  pricePerNight     Float
  totalRooms        Int      @default(10)
  basePricePerNight Float?
  dynamicPricing    Json     @default("{\"enabled\":true,\"peakSeasonMultiplier\":1.5,\"lowOccupancyDiscount\":0.9,\"highDemandMultiplier\":1.3}")
  peakSeasonDates   Json     @default("[]")
  rating            Float    @default(4.5)
  amenities         String[]
  images            String[]
  isAvailable       Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings         Booking[]
  reviews          Review[]
  tripDestinations TripDestination[]
}

model Booking {
  id                  String         @id @default(cuid())
  userId              String?
  hotelId             String
  checkInDate         DateTime
  checkOutDate        DateTime
  guests              Int
  totalPrice          Float
  pricePerNight       Float?
  pricingDetails      Json?
  status              BookingStatus  @default(pending_payment)
  paymentStatus       PaymentStatus  @default(pending)
  paymentId           String?
  paymentMethod       PaymentMethod?
  userName            String
  userEmail           String
  userPhone           String?
  specialRequests     String?
  roomPreferences     String?
  bankDetails         Json?
  bankDetailsSentAt   DateTime?
  paymentConfirmedAt  DateTime?
  paymentConfirmedBy  String?
  modificationHistory Json           @default("[]")
  referralDiscount    Json?
  promoCode           String?
  promoDiscount       Float?
  invoiceNumber       String?        @unique
  invoiceGeneratedAt  DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  hotelId    String
  userId     String
  userName   String
  userAvatar String   @default("https://i.pravatar.cc/150?img=8")
  rating     Float
  comment    String
  helpful    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, userId])
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String
  priceOff    Float
  expiryDate  String
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String
  image     String
  rating    Float    @default(5)
  review    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chat {
  id                  String     @id @default(cuid())
  userId              String
  userName            String
  userEmail           String
  status              ChatStatus @default(active)
  assignedTo          String?
  lastMessageAt       DateTime   @default(now())
  unreadUserMessages  Int        @default(0)
  unreadAdminMessages Int        @default(0)
  ratingScore         Float?
  ratingFeedback      String?
  ratingRatedAt       DateTime?
  createdAt           DateTime   @default(now())

  messages ChatMessage[]
}

model ChatMessage {
  id         String        @id @default(cuid())
  chatId     String
  sender     MessageSender
  senderName String
  senderId   String
  message    String
  timestamp  DateTime      @default(now())
  read       Boolean       @default(false)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Trip {
  id            String     @id @default(cuid())
  userId        String
  tripName      String
  description   String?
  startDate     DateTime
  endDate       DateTime
  totalBudget   Float      @default(0)
  estimatedCost Float      @default(0)
  travelers     Int        @default(1)
  status        TripStatus @default(planning)
  isPublic      Boolean    @default(false)
  shareToken    String?    @unique
  tags          String[]
  coverImage    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  destinations TripDestination[]
}

model TripDestination {
  id       String   @id @default(cuid())
  tripId   String
  city     String
  checkIn  DateTime
  checkOut DateTime
  hotelId  String?
  notes    String?

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  hotel      Hotel?     @relation(fields: [hotelId], references: [id])
  activities Activity[]
}

model Activity {
  id            String           @id @default(cuid())
  destinationId String
  name          String
  description   String?
  date          DateTime?
  time          String?
  location      String?
  estimatedCost Float?
  duration      String?
  category      ActivityCategory @default(other)

  destination TripDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

model Loyalty {
  id                  String      @id @default(cuid())
  userId              String      @unique
  points              Int         @default(0)
  tier                LoyaltyTier @default(bronze)
  totalPointsEarned   Int         @default(0)
  totalPointsRedeemed Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  pointsHistory LoyaltyPointsHistory[]
  tierHistory   LoyaltyTierHistory[]
}

model LoyaltyPointsHistory {
  id          String     @id @default(cuid())
  loyaltyId   String
  type        PointsType
  amount      Int
  bookingId   String?
  description String?
  date        DateTime   @default(now())

  loyalty Loyalty @relation(fields: [loyaltyId], references: [id], onDelete: Cascade)
}

model LoyaltyTierHistory {
  id         String   @id @default(cuid())
  loyaltyId  String
  tier       String
  achievedAt DateTime @default(now())

  loyalty Loyalty @relation(fields: [loyaltyId], references: [id], onDelete: Cascade)
}

model Referral {
  id                  String   @id @default(cuid())
  userId              String   @unique
  referralCode        String   @unique
  totalReferrals      Int      @default(0)
  totalDiscountEarned Float    @default(0)
  totalDiscountGiven  Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  referredUsers ReferredUser[]
}

model ReferredUser {
  id             String   @id @default(cuid())
  referralId     String
  userId         String
  email          String
  bookingId      String?
  discountAmount Float?
  referredAt     DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id                 String       @id @default(cuid())
  code               String       @unique
  description        String
  discountType       DiscountType
  discountValue      Float
  minBookingAmount   Float        @default(0)
  maxDiscount        Float?
  validFrom          DateTime
  validUntil         DateTime
  usageLimit         Int?
  usageCount         Int          @default(0)
  usagePerUser       Int          @default(1)
  applicableHotels   String[]
  isActive           Boolean      @default(true)
  isFirstBookingOnly Boolean      @default(false)
  createdBy          String       @default("admin")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  usedBy PromoCodeUsage[]
}

model PromoCodeUsage {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  bookingId   String?
  usedAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  content         String
  coverImage      String
  category        String
  tags            String[]
  authorId        String
  status          BlogStatus @default(draft)
  isFeatured      Boolean    @default(false)
  views           Int        @default(0)
  readTime        Int        @default(5)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model NewsletterSubscriber {
  id           String    @id @default(cuid())
  email        String    @unique
  subscribedAt DateTime  @default(now())
  isActive     Boolean   @default(true)
  source       String?
}

model CannedResponse {
  id         String         @id @default(cuid())
  title      String
  message    String
  category   CannedCategory @default(other)
  shortcut   String?
  isActive   Boolean        @default(true)
  usageCount Int            @default(0)
  createdBy  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}
